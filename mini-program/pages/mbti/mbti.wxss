/* pages/mbti/mbti.wxss - FBTI 2.0 测试页样式 (V3) */

page {
  background: linear-gradient(180deg, #0d1b2a 0%, #1b2838 50%, #0d1b2a 100%);
  min-height: 100vh;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ====== 引导区 ====== */
.header-section {
  text-align: center;
  padding: 48rpx 0 36rpx;
}
.header-emoji {
  font-size: 96rpx;
  display: block;
  margin-bottom: 16rpx;
  animation: bounce 2s infinite;
}
.header-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFD700;
  display: block;
  letter-spacing: 6rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.header-subtitle {
  font-size: 28rpx;
  color: rgba(255,215,0,0.7);
  display: block;
  margin-top: 6rpx;
  letter-spacing: 4rpx;
}
.header-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 12rpx;
  display: block;
}

/* ====== 进度条 ====== */
.progress-section {
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
}
.progress-bar {
  height: 12rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #FFD700, #FF6B35);
  transition: width 0.3s ease;
}
.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}
.progress-text {
  font-size: 24rpx;
  color: #FFD700;
  font-weight: 600;
}
.progress-dim {
  font-size: 22rpx;
  color: rgba(255,215,0,0.5);
  background: rgba(255,215,0,0.08);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ====== 题目卡片 ====== */
.question-card {
  background: rgba(255,255,255,0.96);
  border-radius: 28rpx;
  padding: 40rpx 36rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.25);
  animation: slideUp 0.4s ease both;
  position: relative;
  overflow: hidden;
}

.hidden-badge {
  position: absolute;
  top: 0;
  right: 24rpx;
  background: linear-gradient(135deg, #9C27B0, #E91E63);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.q-number {
  display: inline-block;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background: linear-gradient(135deg, #0d1b2a, #1b2838);
  color: #FFD700;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.q-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

/* ====== 选项按钮 (V3: 3选项) ====== */
.options {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.option-btn {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 28rpx;
  background: #f8f9fa;
  border: 3rpx solid transparent;
  border-radius: 18rpx;
  transition: all 0.15s ease;
}
.option-btn:active {
  transform: scale(0.98);
  opacity: 0.85;
}
.option-label {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
  border-radius: 18rpx;
  color: #fff;
  flex-shrink: 0;
  letter-spacing: 2px;
}
.option-label-A { background: linear-gradient(135deg, #e74c3c, #c0392b); }
.option-label-B { background: linear-gradient(135deg, #f39c12, #d68910); }
.option-label-C { background: linear-gradient(135deg, #3498db, #2980b9); }
.option-text {
  font-size: 27rpx;
  color: #333;
  line-height: 1.5;
  flex: 1;
}

.option-btn.selected {
  border-color: #0d1b2a;
  background: rgba(13,27,42,0.05);
  box-shadow: 0 4rpx 16rpx rgba(13,27,42,0.15);
}
.option-btn.selected .option-label {
  transform: scale(1.08);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

/* ====== 底部操作栏 ====== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(13, 27, 42, 0.97);
  backdrop-filter: blur(20px);
  z-index: 100;
  display: flex;
  gap: 20rpx;
}
.btn-primary {
  flex: 1;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #FFD700, #FF6B35);
  color: #0d1b2a;
  font-size: 30rpx;
  font-weight: 800;
  border-radius: 44rpx;
  letter-spacing: 2rpx;
  border: none;
  margin: 0;
  padding: 0;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.85; transform: scale(0.98); }
.btn-secondary {
  width: 140rpx;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255,255,255,0.1);
  color: #FFD700;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: 2rpx solid rgba(255,215,0,0.2);
  margin: 0;
  padding: 0;
}
.btn-secondary::after { border: none; }
.btn-secondary:active { opacity: 0.7; }

/* ====== 动画 ====== */
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ====== 完成状态 ====== */
.finish-hint {
  text-align: center;
  color: #FFD700;
  font-size: 28rpx;
  margin-top: 48rpx;
  font-weight: 500;
}
