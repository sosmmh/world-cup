/* pages/profile/profile.wxss - 个人中心 */

page {
  background-color: var(--bg-primary);
}

.profile-page {
  min-height: 100vh;
  padding: 0 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ==================== 用户信息头部 ==================== */
.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.user-avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-btn {
  /* open-type 容器 */
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid var(--secondary-color);
  box-shadow: 0 8rpx 32rpx rgba(255, 215, 0, 0.25);
  background-color: var(--bg-card);
}

.vip-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 3rpx solid var(--bg-primary);
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* ==================== 数据概览 ==================== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx 20rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-sm);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background-color: var(--border-color);
}

/* ==================== 区块通用 ==================== */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-icon {
  font-size: 36rpx;
}

.section-count {
  font-size: 24rpx;
  color: var(--text-muted);
  background-color: rgba(255, 255, 255, 0.06);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ==================== 收藏球员列表 ==================== */
.player-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.player-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-md);
  transition: background-color 0.15s ease;
}

.player-item:active {
  background-color: rgba(255, 255, 255, 0.08);
}

.player-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  overflow: hidden;
}

.player-avatar-sm {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.player-flag {
  font-size: 36rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}

.player-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.player-meta {
  font-size: 22rpx;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.btn-unfav {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: rgba(233, 69, 96, 0.12);
  color: var(--danger-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.btn-unfav:active {
  background-color: rgba(233, 69, 96, 0.25);
}

/* ==================== MBTI测试记录 ==================== */
.latest-result-card {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.08), rgba(233, 69, 96, 0.05));
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.latest-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid;
  margin-bottom: 18rpx;
}

.badge-emoji {
  font-size: 28rpx;
}

.badge-text {
  font-size: 26rpx;
  font-weight: 700;
}

.latest-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.latest-score {
  font-size: 26rpx;
  color: var(--secondary-color);
  font-weight: 600;
}

.latest-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.latest-quote {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 18rpx;
  padding-left: 16rpx;
  border-left: 3rpx solid var(--secondary-color);
}

.btn-view-detail {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
}

/* 测试历史列表 */
.test-history-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.test-history-item {
  display: flex;
  align-items: center;
  padding: 18rpx 12rpx;
  gap: 16rpx;
  border-radius: var(--radius-sm);
  transition: background-color 0.15s;
}

.test-history-item:active {
  background-color: rgba(255, 255, 255, 0.04);
}

.th-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.th-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.th-type {
  font-size: 27rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.th-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.th-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

.btn-retest {
  padding: 8rpx 24rpx;
  background-color: rgba(233, 69, 96, 0.15);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.btn-retest:active {
  background-color: rgba(233, 69, 96, 0.28);
}

/* ==================== 关注球队列表 ==================== */
.team-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.team-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-md);
  transition: background-color 0.15s ease;
}

.team-item:active {
  background-color: rgba(255, 255, 255, 0.08);
}

.team-flag {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.team-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}

.team-name {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.team-group {
  font-size: 22rpx;
  color: var(--text-muted);
}

.btn-unfollow {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: rgba(233, 69, 96, 0.12);
  color: var(--danger-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.btn-unfollow:active {
  background-color: rgba(233, 69, 96, 0.25);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 28rpx;
  text-align: center;
}

.btn-go {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
}

.btn-go:active {
  opacity: 0.85;
}

/* ==================== 底部占位 ==================== */
.bottom-spacer {
  height: 40rpx;
}
