/* pages/tools/tools.wxss - 速成工具箱 */

page {
  background-color: #f5f6fa;
}

.page-container {
  min-height: 100vh;
  padding: 24rpx;
}

/* ========== 头部 ========== */
.header {
  text-align: center;
  padding: 40rpx 0 36rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #888;
  font-weight: 400;
}

/* ========== 工具网格 - 2列布局 ========== */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: space-between;
}

/* ========== 工具卡片 ========== */
.tool-card {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 20rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease;
}

.tool-card:active {
  transform: scale(0.96);
}

/* 图标容器 */
.tool-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.tool-icon {
  font-size: 56rpx;
  line-height: 1;
}

/* 文字 */
.tool-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
  text-align: center;
}

.tool-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
