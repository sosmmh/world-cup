/* pages/index/index.wxss - 首页样式 */

/* ==================== 顶部欢迎区域 ==================== */
.header-section {
  position: relative;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40rpx 30rpx 30rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(233, 69, 96, 0.1);
}

.header-emoji {
  position: absolute;
  top: -20rpx;
  right: 20rpx;
  font-size: 120rpx;
  opacity: 0.15;
}

.header-content {
  position: relative;
  z-index: 1;
}

.greeting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.greeting-text {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.date-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.header-subtitle text {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* MBTI测试入口 */
.mbti-entry {
  margin-top: 28rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(233,69,96,0.15) 0%, rgba(255,215,0,0.08) 100%);
  border-radius: var(--radius-lg);
  border: 2rpx solid rgba(233,69,96,0.25);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.mbti-entry:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.mbti-icon { font-size: 48rpx; }

.mbti-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.mbti-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.mbti-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.mbti-arrow {
  font-size: 36rpx;
  color: var(--primary-color);
}

/* ==================== 通用Section ==================== */
.section {
  padding: 0 30rpx;
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 34rpx;
}

.title-text {
  font-size: 32rpx;
  color: var(--text-primary);
}

.more-btn {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx 16rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.refresh-btn {
  font-size: 32rpx;
}

.update-time {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* ==================== 实时比分区域 ==================== */
.live-section {
  animation: livePulse 2s ease-in-out infinite;
}

@keyframes livePulse {
  0%, 100% { box-shadow: none; }
  50% { box-shadow: 0 0 30rpx rgba(233,69,96,0.15); }
}

.live-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  animation: blink 1.2s ease-in-out infinite;
  margin-right: 4rpx;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.live-label {
  background: var(--primary-color);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  letter-spacing: 2rpx;
}

.live-matches-scroll {
  white-space: nowrap;
}

.live-match-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.live-match-card {
  min-width: 580rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(233,69,96,0.12) 0%, var(--bg-card) 100%);
  border-radius: var(--radius-lg);
  border: 2rpx solid rgba(233,69,96,0.25);
  white-space: normal;
}

.match-teams {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.team {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.team-flag { font-size: 48rpx; }

.team-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.score-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 0 20rpx;
}

.score-text {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--secondary-color);
}

.match-minute {
  font-size: 22rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.match-events {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--border-color);
}

.event-item {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.05);
  color: var(--text-secondary);
}

.event-goal {
  background: rgba(233,69,96,0.15);
  color: var(--primary-color);
}

.event-yellow {
  background: rgba(255,184,0,0.15);
  color: var(--warning-color);
}

/* ==================== 赛程卡片 ==================== */
.matches-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.match-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.05);
  color: var(--text-muted);
}

.status-upcoming {
  background: rgba(0,208,132,0.12);
  color: var(--success-color);
}

.status-finished {
  background: rgba(108,108,126,0.15);
  color: var(--text-muted);
}

.match-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.match-team-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.match-team-flag { font-size: 56rpx; }

.match-team-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  text-align: center;
}

.match-vs-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 30rpx;
}

.vs-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 4rpx;
}

.vs-score {
  font-size: 48rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.score-num {
  color: var(--text-primary);
  transition: all 0.3s;
}

.score-win {
  color: var(--secondary-color);
  transform: scale(1.15);
  display: inline-block;
}

.vs-sep {
  color: var(--text-muted);
  font-size: 32rpx;
}

.match-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.match-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.match-round {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.04);
}

/* ==================== 黑话卡片 ==================== */
.slang-scroll { white-space: nowrap; }

.slang-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.slang-card {
  min-width: 480rpx;
  padding: 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  white-space: normal;
}

.slang-word {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--secondary-color);
  margin-bottom: 12rpx;
}

.slang-meaning {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.slang-tip {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
  background: rgba(255,215,0,0.06);
  padding: 12rpx 16rpx;
  border-radius: var(--radius-md);
}

.tip-label { flex-shrink: 0; }

/* ==================== 球员推荐 ==================== */
.players-scroll { white-space: nowrap; }

.players-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.player-card {
  min-width: 280rpx;
  padding: 28rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  white-space: normal;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.avatar-placeholder {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.player-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.player-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 14rpx;
}

.player-team {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.player-position {
  font-size: 22rpx;
  color: var(--text-muted);
}

.player-quote {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
  font-style: italic;
}

/* ==================== 新闻列表 ==================== */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.news-item {
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
}

.news-item:active {
  opacity: 0.85;
  transform: scale(0.99);
}

.news-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 10rpx;
}

.news-date {
  font-size: 22rpx;
  color: var(--text-muted);
}
